{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🌐 Jekyll Serve",
      "type": "shell",
      "command": "jekyll serve",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Regenerating.*$",
          "endsPattern": "^.*Server running.*$"
        }
      }
    }
  ]
}
